<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Withdraw System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anuphan:wght@100..700&display=swap"
      rel="stylesheet"
    />
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              sans: ["Anuphan", "sans-serif"],
            },
          },
        },
      };
    </script>

    <style>
      body {
        font-family: "Anuphan", sans-serif;
      }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="/js/api.js"></script>
</head>
<body class="bg-gray-100 p-10">
    <div class="max-w-4xl mx-auto">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-2xl font-bold">ถอนเงิน</h1>
            <% if (locals.user) { %>
                <div class="flex items-center gap-3 bg-white px-4 py-2 rounded-full shadow-sm border border-gray-100">
                    <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center text-white text-xs font-bold">
                        <%= user.username.substring(0, 2).toUpperCase() %>
                    </div>
                    <div>
                        <div class="text-sm font-bold text-gray-900"><%= user.username %></div>
                        <div class="text-[10px] text-gray-500 uppercase tracking-wider"><%= user.roles.join(', ') %></div>
                    </div>
                    <a href="/auth/logout" class="ml-2 text-gray-400 hover:text-red-500 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                        </svg>
                    </a>
                </div>
            <% } %>
        </div>
        <div class="bg-white p-8 rounded-2xl shadow-lg">
            <h2 class="text-xl font-bold mb-6 text-gray-800">ระบุข้อมูลการถอนเงิน</h2>

            <% if (locals.error) { %>
                <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-6 rounded shadow-sm">
                    <p><%= error %></p>
                </div>
            <% } %>
            <% if (locals.success) { %>
                <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-6 rounded shadow-sm">
                    <p><%= success %></p>
                </div>
            <% } %>

            <form action="/api/withdraw" method="POST" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="col-span-1 md:col-span-2">
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">จำนวนเงินที่ต้องการถอน</label>
                        <div class="relative group">
                            <input type="number" name="amount" step="0.01" 
                                class="w-full bg-gray-50 border border-gray-200 p-3.5 pl-10 rounded-xl focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 outline-none transition-all duration-200 placeholder:text-gray-400 font-medium" 
                                placeholder="0.00" required>
                            <div class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-blue-500 transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">ธนาคาร</label>
                        <div class="relative">
                            <select name="bank_code" 
                                class="w-full bg-gray-50 border border-gray-200 p-3.5 rounded-xl focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 outline-none transition-all duration-200 cursor-pointer appearance-none pr-10 font-medium text-gray-700" required>
                                <option value="" disabled selected>เลือกธนาคาร</option>
                                <option value="KBANK">กสิกรไทย (KBANK)</option>
                                <option value="SCB">ไทยพาณิชย์ (SCB)</option>
                                <option value="BBL">กรุงเทพ (BBL)</option>
                                <option value="KTB">กรุงไทย (KTB)</option>
                            </select>
                            <div class="absolute right-3.5 top-1/2 -translate-y-1/2 pointer-events-none text-gray-400">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                </svg>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">เบอร์โทรศัพท์</label>
                        <div class="relative group">
                            <input type="text" name="mobile" maxlength="10" 
                                class="w-full bg-gray-50 border border-gray-200 p-3.5 pl-10 rounded-xl focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 outline-none transition-all duration-200 placeholder:text-gray-400 font-medium" 
                                placeholder="08xxxxxxxx" required>
                            <div class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-blue-500 transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                </svg>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">ชื่อบัญชี</label>
                        <div class="relative group">
                            <input type="text" name="bank_acc_name" 
                                class="w-full bg-gray-50 border border-gray-200 p-3.5 pl-10 rounded-xl focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 outline-none transition-all duration-200 placeholder:text-gray-400 font-medium" 
                                placeholder="ชื่อ-นามสกุล" required>
                            <div class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-blue-500 transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">เลขที่บัญชี</label>
                        <div class="relative group">
                            <input type="text" name="bank_acc_number" 
                                class="w-full bg-gray-50 border border-gray-200 p-3.5 pl-10 rounded-xl focus:bg-white focus:ring-4 focus:ring-blue-500/10 focus:border-blue-500 outline-none transition-all duration-200 placeholder:text-gray-400 font-medium" 
                                placeholder="ระบุเลขบัญชี" required>
                            <div class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-blue-500 transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                            </div>
                        </div>
                    </div>
                </div>

                <button type="submit" class="w-full bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-bold py-4 rounded-xl shadow-lg shadow-blue-500/30 transition-all duration-300 hover:-translate-y-0.5 active:translate-y-0 mt-6 flex items-center justify-center gap-2">
                    <span>ส่งคำขอถอนเงิน</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                    </svg>
                </button>
            </form>
        </div>

        <div class="mt-10">
            <h2 class="text-xl font-bold mb-4 text-gray-800">ประวัติการถอนเงิน</h2>
            <div class="bg-white rounded-2xl shadow-lg overflow-hidden border border-gray-100">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-50/50 border-b border-gray-100">
                            <th class="p-4 text-sm font-semibold text-gray-600 uppercase tracking-wider">Order No.</th>
                            <th class="p-4 text-sm font-semibold text-gray-600 uppercase tracking-wider">จำนวน</th>
                            <th class="p-4 text-sm font-semibold text-gray-600 uppercase tracking-wider">สถานะ</th>
                            <th class="p-4 text-sm font-semibold text-gray-600 uppercase tracking-wider text-right">วันที่</th>
                            <% if (hasPermission('WITHDRAW_DELETE')) { %>
                                <th class="p-4 text-sm font-semibold text-gray-600 uppercase tracking-wider text-center">จัดการ</th>
                            <% } %>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                    <% history.forEach(item => { %>
                    <tr class="hover:bg-gray-50/50 transition-colors">
                        <td class="p-4 font-mono text-sm text-gray-600"><%= item.order_no %></td>
                        <td class="p-4">
                            <span class="font-bold text-gray-900"><%= item.amount.toLocaleString() %></span> 
                            <% if(item.real_amount) { %>
                                <div class="text-[10px] text-gray-400 font-medium">โอนจริง: <%= item.real_amount.toLocaleString() %></div>
                            <% } %>
                        </td>
                        <td class="p-4">
                            <% if(item.status == 1) { %> 
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">
                                    <span class="w-1 h-1 mr-1.5 rounded-full bg-green-500"></span>
                                    สำเร็จ
                                </span>
                            <% } else if(item.status == 2) { %> 
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">
                                    <span class="w-1 h-1 mr-1.5 rounded-full bg-red-500"></span>
                                    ปฏิเสธ
                                </span>
                            <% } else { %> 
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700">
                                    <span class="w-1 h-1 mr-1.5 rounded-full bg-yellow-500"></span>
                                    กำลังดำเนินการ
                                </span>
                            <% } %>
                        </td>
                        <td class="p-4 text-xs text-gray-500 text-right"><%= item.created_at.toLocaleString() %></td>
                        <% if (hasPermission('WITHDRAW_DELETE')) { %>
                            <td class="p-4 text-center">
                                <button class="text-red-400 hover:text-red-600 transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                    </svg>
                                </button>
                            </td>
                        <% } %>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        
    </div>
</body>
</html>